# ============================================
# Shared (all services)
# ============================================

# Database (required)
PRIMARY_DATABASE_URL=postgres://user:pass@localhost:5432/openlaunch
REPLICA_DATABASE_URL=postgres://user:pass@localhost:5432/openlaunch
REDIS_URL=redis://localhost:6379

# RPC (required)
MAIN_RPC_URL=https://api.avax.network/ext/bc/C/rpc
SUB_RPC_URL_1=
SUB_RPC_URL_2=
RPC_TIMEOUT_MS=30000

# Contracts (required)
IDO_CONTRACT=0x...
LP_MANAGER_CONTRACT=0x...
USDC_ADDRESS=0x...
CHAIN_ID=43114

# Connection Pool (optional)
PG_PRIMARY_MAX_CONNECTIONS=50
PG_PRIMARY_MIN_CONNECTIONS=5
PG_REPLICA_MAX_CONNECTIONS=200
PG_REPLICA_MIN_CONNECTIONS=10

# ============================================
# API Server
# ============================================
API_IP=0.0.0.0
API_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ============================================
# WebSocket Server
# ============================================
WS_IP=0.0.0.0
WS_PORT=8001
WS_CHANNEL_SIZE=1024
WS_CLEANUP_INTERVAL_SECS=300

# ============================================
# Observer
# ============================================
OBSERVER_POLL_INTERVAL_MS=2000
OBSERVER_BATCH_SIZE=100
OBSERVER_START_BLOCK=0

# ============================================
# TX Bot
# ============================================
GRADUATE_PRIVATE_KEY=0x...
COLLECTOR_PRIVATE_KEY=0x...
GRADUATE_POLL_MS=5000
COLLECT_POLL_SECS=30
GRADUATE_MAX_RETRIES=20
COLLECT_MAX_RETRIES=5
